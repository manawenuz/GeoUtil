# Georgia Utility Monitor - Environment Configuration
# Copy this file to .env.local for local development

# ============================================================================
# STORAGE BACKEND CONFIGURATION
# ============================================================================
# Choose one: redis, postgres, or sqlite
STORAGE_BACKEND=sqlite

# Redis Configuration (if STORAGE_BACKEND=redis)
# For local development with Docker Compose:
# REDIS_URL=redis://localhost:6379
# For Vercel KV:
# KV_URL=your_vercel_kv_url
# KV_REST_API_TOKEN=your_vercel_kv_token

# Postgres Configuration (if STORAGE_BACKEND=postgres)
# For local development with Docker Compose:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/utility_monitor
# For Vercel Postgres:
# POSTGRES_URL=your_vercel_postgres_url
# POSTGRES_PRISMA_URL=your_vercel_postgres_prisma_url

# SQLite Configuration (if STORAGE_BACKEND=sqlite)
# Path to SQLite database file (created automatically)
SQLITE_PATH=./data/utility_monitor.db

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# Encryption key for sensitive data (account numbers, notification URLs)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# NextAuth secret for session encryption
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# NextAuth URL (your app's URL)
# For local development:
NEXTAUTH_URL=http://localhost:3000
# For production:
# NEXTAUTH_URL=https://your-domain.com

# ============================================================================
# GOOGLE OAUTH CONFIGURATION
# ============================================================================
# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============================================================================
# NOTIFICATION CONFIGURATION
# ============================================================================
# Default ntfy.sh server URL (can be overridden per user)
# Use https://ntfy.sh for cloud service or your self-hosted instance
NTFY_SERVER_URL=https://ntfy.sh

# ============================================================================
# SCHEDULER CONFIGURATION
# ============================================================================
# How often to check balances (in hours)
# Default: 72 hours (3 days)
SCHEDULER_INTERVAL_HOURS=72

# Secret for authenticating cron job requests
# Generate with: openssl rand -base64 32
CRON_SECRET=your_cron_secret_here

# ============================================================================
# ENVIRONMENT
# ============================================================================
# Node environment (development, production, test)
NODE_ENV=development

# ============================================================================
# VERCEL-SPECIFIC (automatically set by Vercel)
# ============================================================================
# These are set automatically when deployed to Vercel
# VERCEL=1
# VERCEL_ENV=production
